# ─── Secrets & Environment Variables ──────────────────────────────────────────
# Never commit these — set them in Vercel Dashboard → Settings → Environment Variables
.env
.env.local
.env.*.local
.env.development
.env.production

# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/

# ─── Next.js Build Output ─────────────────────────────────────────────────────
# .next/ is built by Vercel at deploy time — do not commit
.next/
out/

# ─── PWA Service Worker (generated at build time) ─────────────────────────────
# These are auto-generated by next-pwa on every build.
# Vercel runs `npm run build` which regenerates them — no need to commit.
# Committing them would cause stale SW cache issues across deploys.
public/sw.js
public/sw.js.map
public/workbox-*.js
public/workbox-*.js.map

# ─── OS & Editor Noise ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.suo
*.user
.idea/
.vscode/settings.json

# ─── TypeScript Build Info ────────────────────────────────────────────────────
tsconfig.tsbuildinfo

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Agent / AI Workspace (local tooling only) ────────────────────────────────
.agents/
.agent/
